{
  "name": "openclaw-matrix-voice",
  "version": "0.2.0",
  "description": "Matrix voice calls integrated with OpenClaw + Chatterbox TTS",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "docker compose -f docker-compose.test.yml up -d && vitest run tests/integration/ ; docker compose -f docker-compose.test.yml down",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "matrix",
    "voice",
    "openclaw",
    "tts",
    "livekit",
    "whisper"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@livekit/rtc-node": "0.12.2",
    "axios": "1.13.6",
    "dotenv": "16.6.1",
    "express": "4.22.1",
    "livekit-server-sdk": "2.15.0",
    "matrix-bot-sdk": "0.7.1",
    "wavefile": "11.0.0"
  },
  "devDependencies": {
    "@types/express": "4.17.25",
    "@types/node": "20.19.37",
    "eslint": "8.57.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "1.6.1"
  }
}

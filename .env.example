# Matrix Configuration
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@clawmander:matrix.org
MATRIX_ACCESS_TOKEN=your_access_token_here

# OpenClaw API Configuration
OPENCLAW_API_URL=http://localhost:18789
OPENCLAW_API_TOKEN=your_openclaw_token_here

# Chatterbox TTS Configuration
# Option 1: Service mode (local Chatterbox)
CHATTERBOX_TTS_URL=http://localhost:8000/tts
# Option 2: API mode (remote Chatterbox)
# CHATTERBOX_TTS_API_KEY=your_chatterbox_api_key
# CHATTERBOX_TTS_API_URL=https://chatterbox-api.example.com/tts

# Server Configuration
SERVER_PORT=3000
SERVER_HOST=0.0.0.0

# Voice Call Configuration
VOICE_CALL_ROOM_ID=!your_room_id:matrix.org
SAMPLE_RATE=16000
AUDIO_FORMAT=pcm16

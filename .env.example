# ============================================================
# OpenClaw Matrix Voice - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# --- Required: Matrix Configuration ---
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@your-bot:matrix.org
MATRIX_ACCESS_TOKEN=syt_your_access_token_here
# VOICE_CALL_ROOM_ID=!roomid:matrix.org

# --- Required: OpenClaw LLM API ---
OPENCLAW_API_URL=http://localhost:18789
OPENCLAW_API_TOKEN=your_openclaw_token

# --- Required: Chatterbox TTS ---
CHATTERBOX_TTS_URL=http://localhost:8000/tts
# CHATTERBOX_TTS_API_KEY=optional_api_key

# --- Optional: LiveKit (for real-time voice calls) ---
LIVEKIT_ENABLED=false
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# --- Optional: Whisper STT (for real speech-to-text) ---
# WHISPER_URL=http://localhost:8080
# WHISPER_MODEL=whisper-1
# WHISPER_LANGUAGE=en

# --- Audio Pipeline Settings ---
# SAMPLE_RATE=16000
# AUDIO_FORMAT=pcm16
# FRAME_DURATION_MS=20
# AUDIO_CHANNELS=1

# --- VAD (Voice Activity Detection) Tuning ---
# VAD_ENERGY_THRESHOLD=0.3
# VAD_SILENCE_THRESHOLD_MS=800
# VAD_MIN_SPEECH_MS=200
# VAD_PRE_ROLL_MS=100
# VAD_POST_ROLL_MS=300
# VAD_ADAPTIVE_THRESHOLD=false
# VAD_ADAPTIVE_MULTIPLIER=3.0
# VAD_HANGOVER_FRAMES=0
# VAD_DEBUG=false

# --- Server / Health Check ---
# SERVER_PORT=3000
# SERVER_HOST=0.0.0.0

# --- Logging ---
# LOG_LEVEL=info
# NODE_ENV=production
